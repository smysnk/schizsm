# Shared
NODE_ENV=development
WEB_PORT=3000
SERVER_PORT=4000

# Runtime
APP_TITLE="Schizm"
GRAPH_TITLE="Connection Field"
GRAPH_SUBTITLE="Map how fragments attract, collide, and reshape each other."
DEFAULT_THEME=signal
CANVAS_REFRESH_MS=30000
GRAPHQL_ENDPOINT=/graphql
DOCUMENT_STORE_DIR=obsidian-repository

# Postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/schizm
DB_SSL=false
SEED_DEMO_GRAPH=true

# Optional override when the API is not local:
# SERVER_URL=https://your-server-host

# Optional prompt runner container mode
# PROMPT_RUNNER_EXECUTION_MODE=container
# DOCUMENT_STORE_GIT_URL=git@github.com:your-org/your-obsidian-repo.git
# DOCUMENT_STORE_GIT_BRANCH=main
# DOCUMENT_STORE_SSH_PRIVATE_KEY_BASE64=<base64-encoded-private-key>
# DOCUMENT_STORE_GIT_AUTHOR_NAME="Schizm Bot"
# DOCUMENT_STORE_GIT_AUTHOR_EMAIL=schizm-bot@example.com
# PROMPT_RUNNER_CANVAS_REARRANGE_COMMAND=./scripts/rearrange-canvas.sh
# OPENAI_API_KEY=<openai-api-key-for-codex-login>
# CODEX_AUTH_JSON_BASE64=<optional-base64-encoded-codex-auth-json>
