# Shared runtime values for the production API deployment.
# Apply this to the cluster with:
# yarn fleet:env-secret --env-file ./.env.fleet --create-namespace

DATABASE_URL=postgresql://username:password@postgres.example.com:5432/schizm
DB_SSL=true
PROMPT_RUNNER_ENABLED=true
# Production should stay kube-worker. In-process execution is now legacy/debug-only.
PROMPT_RUNNER_EXECUTION_MODE=kube-worker
DOCUMENT_STORE_DIR=/app/obsidian-repository
DOCUMENT_STORE_GIT_URL=git@github.com:your-org/your-obsidian-repo.git
DOCUMENT_STORE_GIT_BRANCH=main
DOCUMENT_STORE_SSH_PRIVATE_KEY_BASE64=<base64-encoded-private-key>
DOCUMENT_STORE_GIT_AUTHOR_NAME="Schizm Bot"
DOCUMENT_STORE_GIT_AUTHOR_EMAIL=schizm-bot@example.com
OPENAI_API_KEY=<openai-api-key-for-codex-login>
CODEX_AUTH_JSON_BASE64=<optional-base64-encoded-codex-auth-json>
